generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Recipe {
  id           String              @id @default(cuid())
  name         String
  servings     Int
  instructions String
  tags         String[]
  favourite    Boolean             @default(false)
  notes        String              @default("")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  ingredients  RecipeIngredient[]
  mealPlanEntries MealPlanEntry[]
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  category          String             @default("other")
  defaultUnit       String             @default("")
  defaultQuantity   Float              @default(1)
  recipeIngredients RecipeIngredient[]
  shoppingListItems ShoppingListItem[]

  @@map("Ingredient")
}

model ShoppingListItem {
  id        Int     @id @default(autoincrement())
  quantity  Float   @default(1)
  unit      String  @default("")
  product   Product @relation(fields: [productId], references: [id])
  productId Int     @map("ingredientId")
}

model RecipeIngredient {
  id          Int     @id @default(autoincrement())
  quantity    Float
  unit        String  @default("")
  preparation String  @default("")
  product     Product @relation(fields: [productId], references: [id])
  productId   Int     @map("ingredientId")
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId    String
}

model MealPlanEntry {
  id             Int             @id @default(autoincrement())
  targetServings Int
  recipe         Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId       String
  scheduledMeals ScheduledMeal[]
}

model ScheduledMeal {
  id              Int           @id @default(autoincrement())
  date            DateTime      @db.Date
  mealType        String
  servings        Int
  mealPlanEntry   MealPlanEntry @relation(fields: [mealPlanEntryId], references: [id], onDelete: Cascade)
  mealPlanEntryId Int
}
