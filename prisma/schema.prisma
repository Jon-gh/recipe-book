generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth required models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  recipes           Recipe[]
  mealPlanEntries   MealPlanEntry[]
  shoppingListItems ShoppingListItem[]
  shoppingSession   ShoppingSession?
  scheduledMeals    ScheduledMeal[]
  products          Product[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ────────────────────────────────────────────────────────────────

model Recipe {
  id           String              @id @default(cuid())
  name         String
  servings     Int
  instructions String
  tags         String[]
  favourite    Boolean             @default(false)
  notes        String              @default("")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients  RecipeIngredient[]
  mealPlanEntries MealPlanEntry[]
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String
  category          String             @default("other")
  defaultUnit       String             @default("")
  defaultQuantity   Float              @default(1)
  source            String             @default("system")
  // null = shared system product; non-null = personal user-added product
  userId            String?
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
  shoppingListItems ShoppingListItem[]

  @@map("Ingredient")
}

model ShoppingListItem {
  id        Int     @id @default(autoincrement())
  quantity  Float   @default(1)
  unit      String  @default("")
  product   Product @relation(fields: [productId], references: [id])
  productId Int     @map("ingredientId")
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecipeIngredient {
  id          Int     @id @default(autoincrement())
  quantity    Float
  unit        String  @default("")
  preparation String  @default("")
  product     Product @relation(fields: [productId], references: [id])
  productId   Int     @map("ingredientId")
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId    String
}

model MealPlanEntry {
  id             Int             @id @default(autoincrement())
  targetServings Int
  recipe         Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId       String
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledMeals ScheduledMeal[]
}

model ScheduledMeal {
  id              Int            @id @default(autoincrement())
  date            DateTime       @db.Date
  mealType        String
  servings        Int
  note            String?
  mealPlanEntry   MealPlanEntry? @relation(fields: [mealPlanEntryId], references: [id], onDelete: Cascade)
  mealPlanEntryId Int?
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ShoppingSession {
  id          String    @id @default(cuid())
  userId      String    @unique
  checkedKeys String[]  @default([])
  showStaples Boolean   @default(false)
  weekStart   DateTime? @db.Date
  weekEnd     DateTime? @db.Date
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
