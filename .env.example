# Neon Postgres — use the *pooled* connection string for DATABASE_URL
# (Add ?pgbouncer=true&connection_limit=1 at the end)
DATABASE_URL="postgresql://user:pass@ep-xxx.pooler.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon Postgres — direct (non-pooled) connection string for migrations
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# Anthropic API key — required for AI import features
ANTHROPIC_API_KEY="sk-ant-..."
