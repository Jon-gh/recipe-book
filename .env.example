# Neon Postgres — use the *pooled* connection string for DATABASE_URL
# (Add ?pgbouncer=true&connection_limit=1 at the end)
DATABASE_URL="postgresql://user:pass@ep-xxx.pooler.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon Postgres — direct (non-pooled) connection string for migrations
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# Anthropic API key — required for AI import features
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth — required for authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""                    # generate with: openssl rand -base64 32

# Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic links (SMTP server for sending sign-in emails)
# Format: smtp://user:password@smtp.example.com:587
# Services: Resend, SendGrid, Postmark, or Gmail SMTP
EMAIL_SERVER=""
EMAIL_FROM=""                         # e.g. "Recipe Book <noreply@yourdomain.com>"
